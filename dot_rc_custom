# Change caps to esc
setxkbmap -option caps:escape

# Set editor to vim
export EDITOR=vim

# Init starship
eval "$(starship init zsh)"

# Init zoxide
eval "$(zoxide init zsh --cmd cd)"

# Aliases
alias ll="ls -al"
alias c="chezmoi "

