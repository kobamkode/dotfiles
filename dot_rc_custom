# Put script below in .zshrc only
# to load zsh-autocomplete plugin after
# pull https://github.com/marlonrichert/zsh-autocomplete:
# source ~/Codes/zsh-autocomplete/zsh-autocomplete.plugin.zsh

# Put script below in .bashrc / .zshrc
# to load this .rc_custom:
# source ~/.rc_custom

# Change caps to esc
setxkbmap -option caps:escape

# Set editor to vim
export EDITOR=vim

# Init starship
eval "$(starship init zsh)"

# Init zoxide
eval "$(zoxide init zsh --cmd cd)"

# Aliases
alias ll="ls -al"
alias c="chezmoi "

